# MeshCore Repeater Placement Analysis Tool — Configuration

# Serial port the USB companion device is connected to
serial_port: "COM3"
baud_rate: 115200

# Repeater of interest — name from contacts or 2-char hex hash (override with --roi)
repeater_of_interest: "MyRepeater_R1"

# Manual path to ROI — skip auto-discovery if set.
#   "" (empty)  — auto-discover path (default)
#   "direct"    — ROI is directly reachable, no intermediates
#   "aa,bb"     — use these hex hashes as intermediate hops
repeater_of_interest_path: ""

# Only include repeaters whose name starts with this prefix (empty = all)
repeater_prefix: ""

# Comma-separated repeater names to exclude from discovery/measurement
exclude_repeaters: ""

# One or more ordered corridors of known waypoints for `invoke findpath` (names
# or 2-char hex hashes). Waypoints in a corridor are comma-separated in route
# order from you outward, e.g. "55,b0,e5"; separate multiple corridors with
# ';', e.g. "55,b0,e5;55,b0,c0,e5". findpath tests each corridor + its ordered
# subsequences, then (if the ROI isn't reached) discovers any unknown tail hops
# anchored at the corridor's far end — so the known crossing isn't re-scanned.
# List your reachable entry node first. Empty = full mesh search.
# Override with --via.
path_candidates: ""

# Repeaters to try when discovering the unknown tail beyond a corridor
# (`invoke findpath`). Comma-separated tokens; each matches a repeater by exact
# name, 2-char hex hash, or name prefix, e.g. "Kyiv_Troieshchyna,14". Use this
# instead of a long exclude list to keep tail discovery from spreading toward
# repeaters that clearly can't reach the ROI. Empty = try the whole pool.
# Override with --tail.
tail_candidates: ""

# Number of SNR trace samples to collect per neighbour
snr_samples: 3

# dB value assigned to timed-out trace attempts when computing averages
timeout_penalty_db: -30

# How many times to retry a flood message / trace before giving up
flood_retries: 3

# Seconds to wait for a trace response
trace_timeout: 15

# Maximum number of intermediate hops to search when finding a path
# (used by `invoke findpath`; override with --max-hops)
max_path_hops: 4
